#!/usr/bin/env bash

LAYOUT="simple"
SESH_CONFIG="$HOME/.config/sesh/sesh.toml"

HISTORY_DIR="$HOME/.local/state/zellij"
HISTORY_FILE="$HISTORY_DIR/session-history"

zellij_switch() {
    zellij pipe --plugin "$HOME/.config/zellij/plugins/zellij-switch.wasm" "$@"
}

# -----------------------------
# Extract layout from sesh.toml
# -----------------------------
get_layout_from_sesh() {
    local session_name="$1"
    local config="$SESH_CONFIG"

    [[ ! -f "$config" ]] && return

    awk -v name="$session_name" '
    $0 ~ /^\[\[session\]\]/ { in_session=1; current_name=""; layout="" }
    in_session && $0 ~ /^name[[:space:]]*=/ {
        gsub(/name[[:space:]]*=[[:space:]]*"/,"")
        gsub(/"/,"")
        current_name=$0
    }
    in_session && $0 ~ /^layout[[:space:]]*=/ {
        gsub(/layout[[:space:]]*=[[:space:]]*"/,"")
        gsub(/"/,"")
        layout=$0
    }
    in_session && current_name==name && layout!="" {
        print layout
        exit
    }
    ' "$config"
}

# -----------------------------
# Session Listing
# -----------------------------
list_zellij_sessions() {
    local sessions=$(zellij list-sessions --short --no-formatting 2>/dev/null)
    [[ -z "$sessions" ]] && return

    local current="$ZELLIJ_SESSION_NAME"
    local result=""

    if [[ -n "$current" ]] && echo "$sessions" | grep -qFx "$current"; then
        result="$current"
    fi

    if [[ -f "$HISTORY_FILE" ]]; then
        while IFS= read -r hist_session; do
            [[ "$hist_session" == "$current" ]] && continue
            echo "$sessions" | grep -qFx "$hist_session" || continue
            result+=$'\n'"$hist_session"
        done <"$HISTORY_FILE"
    fi

    while IFS= read -r session; do
        [[ "$session" == "$current" ]] && continue
        echo "$result" | grep -qFx "$session" && continue
        result+=$'\n'"$session"
    done <<<"$sessions"

    echo "$result" | sed '/^$/d'
}

list_zoxide_dirs() {
    zoxide query -l 2>/dev/null
}

list_combined() {
    list_zellij_sessions
    list_zoxide_dirs
}

# -----------------------------
# Helpers
# -----------------------------
is_existing_session() {
    zellij list-sessions --short --no-formatting 2>/dev/null | grep -qxF "$1"
}

is_directory() {
    [[ -e "$1" && -d "$1" ]]
}

derive_session_name() {
    local path="$1"
    local parent_name=$(basename "$(dirname "$path")")
    local base_name=$(basename "$path")
    echo "${parent_name}-${base_name}"
}

record_session_switch() {
    local session_name="$1"
    [[ -z "$session_name" ]] && return

    mkdir -p "$HISTORY_DIR"

    if [[ -f "$HISTORY_FILE" ]]; then
        grep -vFx "$session_name" "$HISTORY_FILE" >"$HISTORY_FILE.tmp"
        echo "$session_name" >"$HISTORY_FILE"
        cat "$HISTORY_FILE.tmp" >>"$HISTORY_FILE"
        rm "$HISTORY_FILE.tmp"
    else
        echo "$session_name" >"$HISTORY_FILE"
    fi
}

# -----------------------------
# FZF Selection
# -----------------------------
if [ -n "$1" ]; then
    SESS="$1"
else
    SESS=$(list_combined | grep -vE "^(opencode|claude)" | fzf \
            --border-label ' zellij session manager ' --prompt '⚡  ' \
            --header '  ^a all ^t zellij ^x zoxide ^d delete session ^e zoxide erase ^f find' \
            --bind 'tab:down,btab:up' \
            --bind 'ctrl-a:change-prompt(⚡  )+reload(list_combined)' \
            --bind "ctrl-t:change-prompt(🪟  )+reload(list_zellij_sessions)" \
            --bind "ctrl-x:change-prompt(📁  )+reload(list_zoxide_dirs)" \
            --bind 'ctrl-f:change-prompt(🔎  )+reload(fd -L -H -d 5 -t d -E .Trash -E .git -E .cache . ~)' \
            --bind "ctrl-d:execute(zellij kill-session '{}')+reload(list_zellij_sessions)" \
        --bind "ctrl-e:execute(zoxide remove '{}')+reload(list_zoxide_dirs)")
fi

# -----------------------------
# Execution
# -----------------------------
if [[ -n $SESS ]]; then
    SESS="${SESS/#\~/$HOME}"

    if [[ -e "$SESS" ]]; then
        SESS=$(realpath "$SESS")
    fi

    if is_directory "$SESS"; then
        session_name=$(derive_session_name "$SESS")
    else
        session_name="$SESS"
    fi

    layout=$(get_layout_from_sesh "$session_name")
    layout=${layout:-$LAYOUT}

    record_session_switch "$session_name"

    if [[ -n "$ZELLIJ" ]]; then
        if is_existing_session "$session_name"; then
            zellij_switch -- "--session $(printf %q "$session_name") --layout $layout"
        else
            if is_directory "$SESS"; then
                zoxide add "$SESS"
                zellij_switch -- "--session $(printf %q "$session_name") --cwd $(printf %q "$SESS") --layout $layout"
            else
                zellij_switch -- "--session $(printf %q "$session_name") --layout $layout"
            fi
        fi
    else
        if is_directory "$SESS"; then
            zoxide add "$SESS"
            cd "$SESS" && zellij --layout "$layout" attach --create "$session_name"
        else
            zellij --layout "$layout" attach --create "$session_name"
        fi
    fi
fi
