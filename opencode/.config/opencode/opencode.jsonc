{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"edit": "ask",
		"read": {
			"*": "allow",
			"*.env": "ask",
			"*.env.*": "ask",
			"*.env.example": "allow"
		},
		"bash": {
			"*": "ask",

			// read related commands allowed
			"cat *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"less *": "allow",
			"more *": "allow",
			"nl *": "allow",
			"grep *": "allow",
			"rg *": "allow",
			"ls *": "allow",
			"find *": "allow",
			"wc *": "allow",
			"sort *": "allow",
			"uniq *": "allow",
			"which *": "allow",
			"type *": "allow",
			"pwd": "allow",
			"echo *": "allow",
			"printf *": "allow",
			"date": "allow",
			"whoami": "allow",
			"id": "allow",
			"uname *": "allow",
			"df *": "allow",
			"du *": "allow",
			"ps *": "allow",

			// formating commands
			"npx tsc --noEmit*": "allow",
			"npx biome*": "allow",
			"npx prettier*": "allow",
			"npx eslint*": "allow",
			"npx ruff*": "allow",
			"go fmt*": "allow",
			"cargo fmt*": "allow",
			"black*": "allow",
			"ruff format*": "allow",
			"rustfmt*": "allow",

			// env related commands
			"echo $*": "ask",
			"env": "ask",
			"printenv": "ask",
			"export": "ask",
			"set": "ask",

			// anything related with env files
			"*.env": "ask",
			"*.env.*": "ask",
			"*.env.example": "allow"
		}
	},
	"autoupdate": false,
	"plugin": [
		"cursor-acp",
		"@mohak34/opencode-notifier@latest",
		"./plugins/claude-mem.js"
	],
	"provider": {
		"cursor-acp": {
			"name": "Cursor",
			"npm": "@ai-sdk/openai-compatible",
			"options": {
				"baseURL": "http://127.0.0.1:32124/v1"
			},
			"models": {
				"auto": {
